<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" styleClass="module-scroll" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dmvisualizer.controller.ColoringController">
    <VBox spacing="24" styleClass="module-container">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <VBox spacing="6">
            <Label text="Graph Coloring" styleClass="module-title"/>
            <Label text="Apply greedy graph coloring — no two adjacent nodes share the same color." styleClass="module-subtitle"/>
        </VBox>

        <HBox spacing="20">
            <!-- Input -->
            <VBox spacing="16" styleClass="card" minWidth="300">
                <Label text="Graph Input" styleClass="card-title"/>
                <VBox spacing="8">
                    <Label text="Nodes (comma-separated)" styleClass="field-label"/>
                    <TextField fx:id="nodesField" promptText="e.g. A,B,C,D" styleClass="dm-field"/>
                </VBox>
                <VBox spacing="8">
                    <Label text="Edges (comma-separated pairs)" styleClass="field-label"/>
                    <TextArea fx:id="edgesField" promptText="e.g. A-B,B-C,C-D,A-D" prefHeight="80"
                              styleClass="dm-field" wrapText="true"/>
                </VBox>
                <HBox spacing="12">
                    <Button text="Apply Coloring" onAction="#applyColoring" styleClass="btn-primary"/>
                    <Button text="Try Example" onAction="#tryExample" styleClass="btn-example"/>
                </HBox>
                <TextArea fx:id="outputArea" editable="false" prefHeight="160" wrapText="true"
                          styleClass="output-area" promptText="Coloring results will appear here..."/>
            </VBox>

            <!-- Canvas -->
            <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS">
                <Label text="Colored Graph" styleClass="card-title"/>
                <Pane fx:id="graphPane" minHeight="400"
                      style="-fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-radius: 8;"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Graph Coloring" styleClass="op-symbol" style="-fx-font-size:14px;"/>
                <Label text="Assign colors to vertices so adjacent vertices have different colors. Used in scheduling, map coloring, register allocation." styleClass="op-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="8">
                <Label text="Chromatic Number" styleClass="op-symbol" style="-fx-font-size:14px;"/>
                <Label text="The minimum number of colors needed. Greedy algorithm finds a valid coloring, often optimal." styleClass="op-desc" wrapText="true"/>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
