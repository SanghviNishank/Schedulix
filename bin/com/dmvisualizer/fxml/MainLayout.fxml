<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dmvisualizer.controller.MainController"
            styleClass="root-pane">

    <!-- TOP HEADER -->
    <top>
        <HBox styleClass="top-header" alignment="CENTER_LEFT" spacing="16">
            <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
            <Label text="DM" styleClass="logo-dm"/>
            <Label text="Visualizer" styleClass="logo-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="sectionLabel" text="Set Theory" styleClass="section-label"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="v1.0" styleClass="version-label"/>
        </HBox>
    </top>

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" spacing="4" minWidth="220">
            <padding><Insets top="24" right="12" bottom="24" left="12"/></padding>

            <Label text="MODULES" styleClass="sidebar-category"/>

            <Button fx:id="btnSetTheory" text="⊆  Set Theory" styleClass="nav-btn, nav-active"
                    onAction="#loadSetTheory" maxWidth="Infinity"/>
            <Button fx:id="btnRelations" text="↔  Relations" styleClass="nav-btn"
                    onAction="#loadRelations" maxWidth="Infinity"/>
            <Button fx:id="btnHasse" text="⬡  Hasse Diagram" styleClass="nav-btn"
                    onAction="#loadHasse" maxWidth="Infinity"/>
            <Button fx:id="btnGraph" text="⬥  Graph Algorithms" styleClass="nav-btn"
                    onAction="#loadGraph" maxWidth="Infinity"/>

            <Label text="LOGIC &amp; ALGEBRA" styleClass="sidebar-category"/>

            <Button fx:id="btnLogic" text="∧  Logic Truth Table" styleClass="nav-btn"
                    onAction="#loadLogic" maxWidth="Infinity"/>
            <Button fx:id="btnGroup" text="∘  Group Theory" styleClass="nav-btn"
                    onAction="#loadGroup" maxWidth="Infinity"/>

            <Label text="GRAPH THEORY" styleClass="sidebar-category"/>

            <Button fx:id="btnColoring" text="◉  Graph Coloring" styleClass="nav-btn"
                    onAction="#loadColoring" maxWidth="Infinity"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="Discrete Mathematics" styleClass="sidebar-footer"/>
            <Label text="Educational Visualizer" styleClass="sidebar-footer"/>
        </VBox>
    </left>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area"/>
    </center>

</BorderPane>
