<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true" styleClass="module-scroll" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.dmvisualizer.controller.LogicController">
    <VBox spacing="24" styleClass="module-container">
        <padding><Insets top="32" right="32" bottom="32" left="32"/></padding>

        <VBox spacing="6">
            <Label text="Logic Truth Table" styleClass="module-title"/>
            <Label text="Enter a boolean expression and generate its complete truth table." styleClass="module-subtitle"/>
        </VBox>

        <VBox spacing="16" styleClass="card">
            <Label text="Expression Input" styleClass="card-title"/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <TextField fx:id="exprField" promptText="e.g. (A &amp;&amp; B) || !C" styleClass="dm-field" HBox.hgrow="ALWAYS"/>
                <Button text="Generate Table" onAction="#generateTable" styleClass="btn-primary"/>
                <Button text="Try Example" onAction="#tryExample" styleClass="btn-example"/>
            </HBox>
            <Label text="Supported operators: &amp;&amp; (AND), || (OR), ! (NOT), ^ (XOR), -&gt; (IMPLIES)" styleClass="field-label"/>
        </VBox>

        <VBox spacing="12" styleClass="card" VBox.vgrow="ALWAYS">
            <Label text="Truth Table" styleClass="card-title"/>
            <TableView fx:id="truthTable" prefHeight="360" styleClass="dm-table"/>
        </VBox>

        <HBox spacing="16">
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label text="&&" styleClass="op-symbol"/>
                <Label text="AND — true only if both inputs are true" styleClass="op-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label text="||" styleClass="op-symbol"/>
                <Label text="OR — true if at least one input is true" styleClass="op-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label text="!" styleClass="op-symbol"/>
                <Label text="NOT — negates the input value" styleClass="op-desc" wrapText="true"/>
            </VBox>
            <VBox styleClass="info-card" HBox.hgrow="ALWAYS" spacing="6">
                <Label text="^" styleClass="op-symbol"/>
                <Label text="XOR — true if inputs differ" styleClass="op-desc" wrapText="true"/>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
